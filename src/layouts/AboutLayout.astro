---
import ChevronRight from "@lucide/astro/icons/chevron-right";
import Languages from "@lucide/astro/icons/languages";
import Menu from "@lucide/astro/icons/menu";
import Moon from "@lucide/astro/icons/moon";
import Settings from "@lucide/astro/icons/settings";
import Sun from "@lucide/astro/icons/sun";
import X from "@lucide/astro/icons/x";
import type { AboutCommonCopy, AboutPageMeta } from "../content/types";
import {
  ABOUT_LOCALE_META,
  ABOUT_LOCALES,
  type AboutLocale,
  type AboutPageId,
  DEFAULT_LOCALE,
  getAppEntryUrl,
  getCanonicalUrl,
  getPagePath,
} from "../i18n/locales";
import "../styles/site.css";

type Props = {
  locale: AboutLocale;
  page: AboutPageId;
  common: AboutCommonCopy;
  meta: AboutPageMeta;
};

const { locale, page, common, meta } = Astro.props;
const localeMeta = ABOUT_LOCALE_META[locale];
const githubUrl = "https://github.com/rezics";
const alternateLinks = ABOUT_LOCALES.map((alternateLocale) => ({
  locale: alternateLocale,
  href: getPagePath(alternateLocale, page),
  canonical: getCanonicalUrl(alternateLocale, page),
  meta: ABOUT_LOCALE_META[alternateLocale],
}));
---

<!doctype html>
<html lang={localeMeta.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <script is:inline>
      (() => {
        try {
          const storedTheme = localStorage.getItem("rezics-theme");
          document.documentElement.classList.toggle("dark", storedTheme === "dark");
          document.documentElement.classList.toggle("light", storedTheme !== "dark");
        } catch {
          document.documentElement.classList.add("light");
        }
      })();
    </script>
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    {
      alternateLinks.map((link) => (
        <link rel="alternate" hreflang={link.meta.htmlLang} href={link.canonical} />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={getCanonicalUrl(DEFAULT_LOCALE, page)}
    />
    <link rel="canonical" href={getCanonicalUrl(locale, page)} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Rezics" />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={getCanonicalUrl(locale, page)} />
  </head>
  <body class="min-h-screen bg-surface-canvas text-text-primary font-sans antialiased">
    <header class="sticky top-0 z-10 border-b border-border-whisper bg-surface-canvas">
      <div class="w-full max-w-7xl mx-auto flex h-16 items-center gap-4 px-6 sm:px-8 lg:gap-8">
        <a
          class="shrink-0 inline-flex items-center text-text-brand no-underline"
          href={getPagePath(locale, "home")}
          aria-label="Rezics"
        >
          <img class="h-6 w-auto" src="/logo.svg" alt="" width="34" height="24" />
        </a>
        <nav class="hidden min-w-0 flex-1 items-center gap-2 md:flex lg:justify-center" aria-label="Primary navigation">
          <a
            class:list={[
              "rounded-md px-3 py-2 text-sm leading-[1.4] no-underline transition-colors",
              page === "home"
                ? "bg-surface-subtle text-text-brand"
                : "text-text-secondary hover:text-text-primary",
            ]}
            aria-current={page === "home" ? "page" : undefined}
            href={getPagePath(locale, "home")}
          >
            {common.nav.home}
          </a>
          <a
            class:list={[
              "rounded-md px-3 py-2 text-sm leading-[1.4] no-underline transition-colors",
              page === "product"
                ? "bg-surface-subtle text-text-brand"
                : "text-text-secondary hover:text-text-primary",
            ]}
            aria-current={page === "product" ? "page" : undefined}
            href={getPagePath(locale, "product")}
          >
            {common.nav.product}
          </a>
        </nav>
        <div class="hidden min-w-0 shrink-0 items-center gap-2 md:flex">
          <a
            class="inline-flex h-10 shrink-0 items-center justify-center rounded-full bg-brand-fill px-4 text-sm font-semibold leading-[1.4] text-text-on-brand no-underline transition-colors hover:bg-brand-fill-hover"
            href={getAppEntryUrl(locale)}
          >
            {common.nav.app}
          </a>
          <a
            class="inline-flex h-10 shrink-0 items-center justify-center gap-2 rounded-full border border-border-defined px-4 text-sm font-semibold leading-[1.4] text-text-primary no-underline transition-colors hover:bg-surface-subtle"
            href={githubUrl}
            title="GitHub"
            target="_blank"
            rel="noreferrer"
          >
            <img class="h-4 w-4" src="/icons/github.svg" alt="" width="16" height="16" />
            <span>GitHub</span>
          </a>
          <details class="settings-switcher relative" data-settings-menu>
            <summary class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-full text-text-secondary transition-colors hover:bg-surface-subtle hover:text-text-primary" aria-label="Settings">
              <Settings class="h-4 w-4" aria-hidden="true" />
            </summary>
            <div class="settings-popover absolute right-0 top-[calc(100%+0.65rem)] z-20 grid w-64 gap-3 rounded-md border border-border-whisper bg-surface-base p-3 shadow-modal">
              <button
                class="flex min-h-10 w-full items-center justify-between rounded-md bg-transparent px-3 text-left text-sm font-medium leading-[1.4] text-text-primary transition-colors hover:bg-surface-subtle"
                type="button"
                aria-label={common.theme.toggle}
                aria-pressed="false"
                title={common.theme.toggle}
                data-theme-toggle
                data-light-label={common.theme.light}
                data-dark-label={common.theme.dark}
              >
                <span data-theme-label>{common.theme.light}</span>
                <span class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-border-defined">
                  <Sun class="h-4 w-4" aria-hidden="true" data-theme-icon="light" />
                  <Moon class="hidden h-4 w-4" aria-hidden="true" data-theme-icon="dark" />
                </span>
              </button>
              <div class="grid gap-1 border-t border-border-whisper pt-3">
                <p class="m-0 px-3 text-xs font-medium leading-[1.4] text-text-tertiary">{common.nav.language}</p>
                {
                  alternateLinks.map((link) => (
                    <a
                      class:list={[
                        "rounded-sm px-3 py-2 text-sm leading-[1.4] no-underline",
                        link.locale === locale
                          ? "bg-surface-subtle text-text-brand"
                          : "text-text-secondary hover:bg-surface-subtle hover:text-text-primary",
                      ]}
                      aria-current={link.locale === locale ? "true" : undefined}
                      lang={link.meta.htmlLang}
                      href={link.href}
                    >
                      {link.meta.nativeName}
                    </a>
                  ))
                }
              </div>
            </div>
          </details>
        </div>
        <div class="ml-auto flex shrink-0 items-center gap-3 md:hidden">
          <a
            class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-border-defined text-text-primary no-underline transition-colors hover:bg-surface-subtle"
            href={githubUrl}
            aria-label="GitHub"
            title="GitHub"
            target="_blank"
            rel="noreferrer"
          >
            <img class="h-4 w-4" src="/icons/github.svg" alt="" width="16" height="16" />
          </a>
          <button
            class="inline-flex h-9 w-9 items-center justify-center rounded-md text-text-primary transition-colors hover:bg-surface-subtle"
            type="button"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
            data-mobile-menu-toggle
          >
            <Menu class="h-5 w-5" aria-hidden="true" data-menu-icon="open" />
            <X class="hidden h-5 w-5" aria-hidden="true" data-menu-icon="close" />
          </button>
        </div>
      </div>
      <div id="mobile-menu" class="mobile-menu md:hidden" data-mobile-menu hidden>
        <nav class="w-full max-w-7xl mx-auto px-6 pb-5 pt-2 sm:px-8" aria-label="Mobile navigation">
          <div class="grid border-b border-border-whisper">
            <a
              class:list={[
                "flex min-h-14 items-center justify-between border-b border-border-whisper text-base font-medium leading-[1.4] no-underline",
                page === "home" ? "text-text-brand" : "text-text-primary",
              ]}
              aria-current={page === "home" ? "page" : undefined}
              href={getPagePath(locale, "home")}
            >
              <span>{common.nav.home}</span>
              <ChevronRight class="h-4 w-4 text-text-tertiary" aria-hidden="true" />
            </a>
            <a
              class:list={[
                "flex min-h-14 items-center justify-between border-b border-border-whisper text-base font-medium leading-[1.4] no-underline",
                page === "product" ? "text-text-brand" : "text-text-primary",
              ]}
              aria-current={page === "product" ? "page" : undefined}
              href={getPagePath(locale, "product")}
            >
              <span>{common.nav.product}</span>
              <ChevronRight class="h-4 w-4 text-text-tertiary" aria-hidden="true" />
            </a>
            <a
              class="flex min-h-14 items-center justify-between border-b border-border-whisper text-base font-medium leading-[1.4] text-text-primary no-underline"
              href={getAppEntryUrl(locale)}
            >
              <span>{common.nav.app}</span>
              <ChevronRight class="h-4 w-4 text-text-tertiary" aria-hidden="true" />
            </a>
            <button
              class="flex min-h-14 w-full items-center justify-between border-b border-border-whisper bg-transparent p-0 text-left text-base font-medium leading-[1.4] text-text-primary"
              type="button"
              aria-label={common.theme.toggle}
              aria-pressed="false"
              title={common.theme.toggle}
              data-theme-toggle
              data-light-label={common.theme.light}
              data-dark-label={common.theme.dark}
            >
              <span data-theme-label>{common.theme.light}</span>
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-border-defined">
                <Sun class="h-4 w-4" aria-hidden="true" data-theme-icon="light" />
                <Moon class="hidden h-4 w-4" aria-hidden="true" data-theme-icon="dark" />
              </span>
            </button>
            <details class="language-switcher">
              <summary class="flex min-h-14 cursor-pointer list-none items-center justify-between text-base font-medium leading-[1.4] text-text-primary">
                <span class="inline-flex items-center gap-2">
                  <Languages class="h-4 w-4 text-text-tertiary" aria-hidden="true" />
                  {common.nav.language}
                </span>
                <ChevronRight class="h-4 w-4 text-text-tertiary" aria-hidden="true" />
              </summary>
              <div class="grid gap-1 pb-4">
                {
                  alternateLinks.map((link) => (
                    <a
                      class:list={[
                        "rounded-sm px-3 py-2 text-sm leading-[1.4] no-underline",
                        link.locale === locale
                          ? "bg-surface-subtle text-text-brand"
                          : "text-text-secondary hover:bg-surface-subtle hover:text-text-primary",
                      ]}
                      aria-current={link.locale === locale ? "true" : undefined}
                      lang={link.meta.htmlLang}
                      href={link.href}
                    >
                      {link.meta.nativeName}
                    </a>
                  ))
                }
              </div>
            </details>
          </div>
        </nav>
      </div>
    </header>
    <main class="w-full">
      <slot />
    </main>
    <footer class="w-full border-t border-border-whisper">
      <div class="w-full max-w-6xl mx-auto grid gap-3 px-6 py-8 text-sm leading-[1.55] text-text-tertiary sm:px-8 md:grid-cols-[auto_minmax(0,1fr)] md:justify-between md:gap-8">
        <p class="m-0 text-text-primary">Rezics</p>
        <p class="m-0 md:text-right">{common.footer.originNote}</p>
      </div>
    </footer>
    <script>
      const syncThemeToggle = () => {
        const isDark = document.documentElement.classList.contains("dark");
        document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]").forEach((button) => {
          const label = button.querySelector<HTMLElement>("[data-theme-label]");
          const lightIcon = button.querySelector<SVGElement>('[data-theme-icon="light"]');
          const darkIcon = button.querySelector<SVGElement>('[data-theme-icon="dark"]');

          button.setAttribute("aria-pressed", String(isDark));
          if (label) {
            label.textContent = isDark ? button.dataset.darkLabel ?? "Dark" : button.dataset.lightLabel ?? "Light";
          }
          lightIcon?.classList.toggle("hidden", isDark);
          darkIcon?.classList.toggle("hidden", !isDark);
        });
      };

      document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]").forEach((button) => {
        button.addEventListener("click", () => {
          const root = document.documentElement;
          const nextTheme = document.documentElement.classList.contains("dark") ? "light" : "dark";

          root.classList.add("theme-switching");
          root.classList.toggle("dark", nextTheme === "dark");
          root.classList.toggle("light", nextTheme === "light");
          localStorage.setItem("rezics-theme", nextTheme);
          syncThemeToggle();
          requestAnimationFrame(() => {
            root.classList.remove("theme-switching");
          });
        });
      });
      syncThemeToggle();

      const mobileMenu = document.querySelector<HTMLElement>("[data-mobile-menu]");
      const mobileMenuToggle = document.querySelector<HTMLButtonElement>("[data-mobile-menu-toggle]");
      const openMenuIcon = mobileMenuToggle?.querySelector<SVGElement>('[data-menu-icon="open"]');
      const closeMenuIcon = mobileMenuToggle?.querySelector<SVGElement>('[data-menu-icon="close"]');
      let mobileMenuCloseTimer: number | undefined;

      const setMobileMenuOpen = (isOpen: boolean) => {
        if (!mobileMenu || !mobileMenuToggle) {
          return;
        }

        window.clearTimeout(mobileMenuCloseTimer);
        if (isOpen) {
          mobileMenu.hidden = false;
          mobileMenu.classList.remove("hidden");
          requestAnimationFrame(() => {
            mobileMenu.classList.add("is-open");
          });
        } else {
          mobileMenu.classList.remove("is-open");
          mobileMenuCloseTimer = window.setTimeout(() => {
            mobileMenu.hidden = true;
            mobileMenu.classList.add("hidden");
          }, 180);
        }
        mobileMenuToggle.setAttribute("aria-expanded", String(isOpen));
        mobileMenuToggle.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
        openMenuIcon?.classList.toggle("hidden", isOpen);
        closeMenuIcon?.classList.toggle("hidden", !isOpen);
        document.body.classList.toggle("mobile-menu-open", isOpen);
      };

      mobileMenuToggle?.addEventListener("click", () => {
        setMobileMenuOpen(mobileMenuToggle.getAttribute("aria-expanded") !== "true");
      });

      mobileMenu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => setMobileMenuOpen(false));
      });

      document.querySelectorAll<HTMLDetailsElement>("[data-settings-menu]").forEach((settingsMenu) => {
        document.addEventListener("click", (event) => {
          if (settingsMenu.open && !settingsMenu.contains(event.target as Node)) {
            settingsMenu.open = false;
          }
        });
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          setMobileMenuOpen(false);
          document.querySelectorAll<HTMLDetailsElement>("[data-settings-menu]").forEach((settingsMenu) => {
            settingsMenu.open = false;
          });
        }
      });
    </script>
  </body>
</html>
