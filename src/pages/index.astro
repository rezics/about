---
import {
  ABOUT_LOCALES,
  DEFAULT_LOCALE,
  getCanonicalUrl,
  getPagePath,
} from "../i18n/locales";

const defaultPath = getPagePath(DEFAULT_LOCALE, "home");
const localizedPaths = Object.fromEntries(
  ABOUT_LOCALES.map((locale) => [locale, getPagePath(locale, "home")]),
);
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <link rel="canonical" href={getCanonicalUrl(DEFAULT_LOCALE, "home")} />
    <script is:inline define:vars={{ defaultPath, localizedPaths }}>
      const normalizeLocaleTag = (value) =>
        value.trim().toLowerCase().replaceAll("_", "-");

      const matchLocale = (value) => {
        const tag = normalizeLocaleTag(value);

        if (localizedPaths[tag]) {
          return tag;
        }

        if (tag.startsWith("zh-")) {
          if (
            tag.startsWith("zh-hant") ||
            ["zh-tw", "zh-hk", "zh-mo"].some((prefix) => tag.startsWith(prefix))
          ) {
            return "zh-hant";
          }

          if (
            tag.startsWith("zh-hans") ||
            ["zh-cn", "zh-sg"].some((prefix) => tag.startsWith(prefix))
          ) {
            return "zh-hans";
          }

          return "zh-hant";
        }

        const baseLanguage = tag.split("-")[0];
        return localizedPaths[baseLanguage] ? baseLanguage : undefined;
      };

      const languages = navigator.languages?.length
        ? navigator.languages
        : [navigator.language];
      const matchedLocale = languages.map(matchLocale).find(Boolean);

      window.location.replace(
        matchedLocale ? localizedPaths[matchedLocale] : defaultPath,
      );
    </script>
    <noscript>
      <meta http-equiv="refresh" content={`0; url=${defaultPath}`} />
    </noscript>
    <title>Rezics</title>
  </head>
  <body>
    <a href={defaultPath}>Rezics</a>
  </body>
</html>
