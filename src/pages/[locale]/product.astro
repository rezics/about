---
import ArrowRight from "@lucide/astro/icons/arrow-right";
import MarkdownFragment from "../../components/MarkdownFragment.astro";
import { getCommonCopy, getProductPageCopy } from "../../content/aboutContent";
import {
  ABOUT_LOCALES,
  type AboutLocale,
  getProductDetailPath,
} from "../../i18n/locales";
import AboutLayout from "../../layouts/AboutLayout.astro";

export function getStaticPaths() {
  return ABOUT_LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as AboutLocale;
const common = getCommonCopy(locale);
const copy = getProductPageCopy(locale);
---

<AboutLayout locale={locale} page="product" common={common} meta={copy.meta}>
  <section class="w-full max-w-7xl mx-auto px-6 py-16 sm:px-8 lg:py-24">
    <div class="grid gap-8 lg:max-w-4xl">
      <div class="grid gap-5">
        <p class="m-0 text-sm font-medium leading-[1.4] text-text-brand">{copy.hero.eyebrow}</p>
        <h1 class="m-0 text-[clamp(2.4rem,5vw,4.75rem)] font-semibold leading-[1.03] tracking-normal text-text-primary">
          {copy.hero.heading}
        </h1>
      </div>
      <div class="about-prose about-prose-hero grid max-w-3xl gap-4 text-[1.0625rem] leading-[1.75] text-text-secondary sm:text-lg">
        <MarkdownFragment locale={locale} page="product" slug="hero" />
      </div>
    </div>
  </section>

  <section class="w-full border-t border-border-whisper bg-surface-subtle">
    <div class="w-full max-w-7xl mx-auto grid gap-5 px-6 py-14 sm:px-8 md:grid-cols-2 lg:grid-cols-4 lg:py-20">
      {
        copy.products.map((product) => (
          <a
            class="group grid min-h-[22rem] content-between rounded-md border border-border-whisper bg-surface-canvas p-6 text-text-primary no-underline transition-colors hover:border-border-defined hover:bg-surface-base"
            href={getProductDetailPath(locale, product.slug)}
          >
            <div class="min-w-0">
              <div class="mb-5 flex flex-wrap items-center gap-2">
                <span class="inline-flex min-h-7 shrink-0 items-center rounded-md bg-surface-subtle px-2.5 text-xs font-medium leading-[1.4] text-text-secondary">
                  {product.category}
                </span>
                <span
                  class:list={[
                    "inline-flex min-h-7 shrink-0 items-center rounded-md bg-surface-subtle px-2.5 text-xs font-medium leading-[1.4]",
                    product.status === "available"
                      ? "text-text-brand"
                      : "text-text-tertiary",
                  ]}
                >
                  {product.statusLabel}
                </span>
              </div>
              <h2 class="m-0 mb-4 text-2xl font-semibold leading-[1.2] tracking-normal text-text-primary">
                {product.name}
              </h2>
              <p class="m-0 text-base leading-[1.65] text-text-secondary">{product.summary}</p>
            </div>
            <div class="mt-8 flex items-center justify-between gap-4 border-t border-border-whisper pt-5 text-sm font-semibold leading-[1.4] text-text-brand">
              <span>{product.ctaLabel}</span>
              <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" aria-hidden="true" />
            </div>
          </a>
        ))
      }
    </div>
  </section>
</AboutLayout>
