---
import MarkdownFragment from "../../components/MarkdownFragment.astro";
import { getCommonCopy, getProductPageCopy } from "../../content/aboutContent";
import { ABOUT_LOCALES, type AboutLocale } from "../../i18n/locales";
import AboutLayout from "../../layouts/AboutLayout.astro";

export function getStaticPaths() {
  return ABOUT_LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as AboutLocale;
const common = getCommonCopy(locale);
const copy = getProductPageCopy(locale);
---

<AboutLayout locale={locale} page="product" common={common} meta={copy.meta}>
  <section class="w-full max-w-6xl mx-auto px-6 py-20 sm:px-8 lg:py-28">
    <div class="grid gap-8 lg:max-w-4xl">
      <div class="grid gap-5">
        <p class="m-0 text-sm font-medium leading-[1.4] text-text-brand">{copy.hero.eyebrow}</p>
        <h1 class="m-0 text-3xl font-medium leading-none tracking-normal text-text-primary">
          {copy.hero.heading}
        </h1>
      </div>
      <div class="about-prose about-prose-hero grid max-w-3xl gap-4 text-lg leading-[1.55] text-text-secondary">
        <MarkdownFragment locale={locale} page="product" slug="hero" />
      </div>
    </div>
  </section>

  <section class="w-full max-w-6xl mx-auto px-6 py-10 sm:px-8 lg:py-14">
    <div class="border-y border-border-whisper">
      {
        copy.products.map((product) => (
          <article class="grid gap-6 border-b border-border-whisper py-8 last:border-b-0 lg:grid-cols-[minmax(0,0.46fr)_minmax(18rem,0.54fr)] lg:gap-12">
            <div class="min-w-0">
              <div class="mb-4 flex flex-wrap items-center gap-2">
                <span class="inline-flex min-h-7 shrink-0 items-center rounded-md bg-surface-subtle px-2.5 text-xs font-medium leading-[1.4] text-text-secondary">
                  {product.category}
                </span>
                <span
                  class:list={[
                    "inline-flex min-h-7 shrink-0 items-center rounded-md bg-surface-subtle px-2.5 text-xs font-medium leading-[1.4]",
                    product.status === "available"
                      ? "text-text-brand"
                      : "text-text-tertiary",
                  ]}
                >
                  {product.statusLabel}
                </span>
              </div>
              <h2 class="m-0 mb-3 text-2xl font-medium leading-[1.4] text-text-primary">
                {product.name}
              </h2>
              <p class="m-0 text-base leading-[1.55] text-text-secondary">{product.summary}</p>
            </div>
            <div class="grid min-w-0 gap-5">
              <ul class="m-0 grid gap-2 pl-5 text-base leading-[1.55] text-text-secondary">
                {product.features.map((feature) => <li>{feature}</li>)}
              </ul>
              {
                product.href && product.ctaLabel ? (
                  <a
                    class="inline-flex min-h-10 w-fit shrink-0 items-center justify-center rounded-md border border-border-defined px-3 py-2 text-sm font-medium leading-[1.4] text-text-primary no-underline transition-colors hover:bg-surface-subtle"
                    href={product.href}
                    target="_blank"
                    rel="noreferrer"
                  >
                    {product.ctaLabel}
                  </a>
                ) : null
              }
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="w-full max-w-6xl mx-auto grid gap-8 px-6 py-14 sm:px-8 md:grid-cols-2 lg:py-16">
    {
      copy.sections.map((section) => (
        <article class="min-w-0 border-t border-border-defined pt-6">
          <p class="m-0 mb-3 text-sm font-medium leading-[1.4] text-text-brand">{section.eyebrow}</p>
          <h2 class="m-0 mb-4 text-2xl font-medium leading-[1.4] text-text-primary">
            {section.title}
          </h2>
          <p class="m-0 text-base leading-[1.55] text-text-secondary">{section.body}</p>
        </article>
      ))
    }
  </section>

  <section class="w-full max-w-6xl mx-auto grid gap-8 px-6 py-14 sm:px-8 lg:py-16">
    {
      copy.storySections.map((section) => (
        <article class="grid gap-4 border-t border-border-whisper pt-6 md:grid-cols-[minmax(10rem,0.32fr)_minmax(0,0.68fr)] md:gap-12">
          <p class="m-0 text-sm font-medium leading-[1.4] text-text-brand">{section.eyebrow}</p>
          <div class="min-w-0">
            <h2 class="m-0 mb-4 text-2xl font-medium leading-[1.4] text-text-primary">
              {section.title}
            </h2>
            <p class="m-0 text-base leading-[1.55] text-text-secondary">{section.body}</p>
          </div>
        </article>
      ))
    }
  </section>

  <section class="w-full max-w-6xl mx-auto px-6 py-14 sm:px-8 lg:py-16">
    <article class="about-prose grid max-w-3xl gap-4 text-base leading-[1.55] text-text-secondary">
      <MarkdownFragment locale={locale} page="product" slug="closing" />
    </article>
  </section>
</AboutLayout>
